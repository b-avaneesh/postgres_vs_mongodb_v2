{
  "name": "postgres_vs_mongo_v2",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "tsx watch src/server.ts",
    "dev:postgres": "npm run dev -w packages/postgres",
    "dev:mongo": "npm run dev -w packages/mongo",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:postgres\" \"npm run dev:mongo\""
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.1.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@json2csv/plainjs": "^7.0.6",
    "@types/express": "^5.0.6",
    "axios": "^1.18.1",
    "express": "^5.2.1",
    "json2csv": "^6.0.0-alpha.2",
    "uuid": "^14.0.1"
  }
}
